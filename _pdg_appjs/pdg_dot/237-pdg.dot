  "30064774891" -> "124554051830"  [ label = "DDG: reducer"] 
  "30064774891" -> "124554051830"  [ label = "DDG: function reducer = function reducer(state, element) {
  const newState = {...state, [element.name]: element.checked};

  global.localStorage.setItem(STORAGE_KEY, JSON.stringify(newState));
  return newState;
}"] 
