  "30064790343" -> "124554052829"  [ label = "DDG: function getIDAndRevisionFromHash = function getIDAndRevisionFromHash() {
  let match = global.location.hash.match(/^#\/(?!gist\/)([^/]+)(?:\/(latest|\d*))?/);
  if (match) {
    return {
      id: match[1],
      rev: match[2] || 0,
    };
  }
  return null;
}"] 
  "30064790344" -> "124554052829"  [ label = "DDG: fetchSnippet"] 
  "30064790344" -> "124554052829"  [ label = "DDG: function fetchSnippet = function fetchSnippet(snippetID, revisionID='latest') {
  return api(`/parse/${snippetID}/${revisionID}`)
    .then(response =&gt; {
      if (response.ok) {
        return response.json();
      }
      switch (response.status) {
        case 404:
          throw new Error(`Snippet with ID ${snippetID}/${revisionID} doesn't exist.`);
        default:
          throw new Error('Unknown error.');
      }
    })
    .then(response =&gt; new Revision(response));
}"] 
