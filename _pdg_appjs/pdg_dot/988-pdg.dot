  "30064787328" -> "124554052584"  [ label = "DDG: function set = function set(words) {
    let obj = {};
    for (let i = 0; i &lt; words.length; ++i) obj[words[i]] = true;
    return obj;
  }"] 
  "30064787329" -> "124554052584"  [ label = "DDG: tokenPolymorphicVar"] 
  "30064787329" -> "124554052584"  [ label = "DDG: function tokenPolymorphicVar = function tokenPolymorphicVar(stream, state) {
    /* A char can't have more than 4 characters */
    let count = 0;
    let next; //eslint-disable-line no-unused-vars
    while ((next = stream.next()) != null) {
      // char
      if (stream.eat(&quot;'&quot;) &amp;&amp; count &lt;= 4) {
        state.tokenize = null;
        return 'string';
      }
      // Polymorphic variable
      if (!/\w/.test(stream.peek())) {
        state.tokenize = null;
        return 'variable-2';
      }
      count++;
    }
    state.tokenize = null;
    return null;
  }"] 
  "30064787330" -> "124554052584"  [ label = "DDG: tokenString"] 
  "30064787330" -> "124554052584"  [ label = "DDG: function tokenString = function tokenString(stream, state) {
    let next,
      end = false,
      escaped = false;
    while ((next = stream.next()) != null) {
      if (next === '&quot;' &amp;&amp; !escaped) {
        end = true;
        break;
      }
      escaped = !escaped &amp;&amp; next === '\\';
    }
    if (end &amp;&amp; !escaped) {
      state.tokenize = false;
    }
    return 'string';
  }"] 
  "30064787331" -> "124554052584"  [ label = "DDG: tokenNestedComment"] 
  "30064787331" -> "124554052584"  [ label = "DDG: function tokenNestedComment = function tokenNestedComment(depth) {
    return function(stream, state) {
      let ch;
      while ((ch = stream.next())) {
        if (ch == '*' &amp;&amp; stream.eat('/')) {
          if (depth == 1) {
            state.tokenize = null;
            break;
          } else {
            state.tokenize = tokenNestedComment(depth - 1);
            return state.tokenize(stream, state);
          }
        } else if (ch == '/' &amp;&amp; stream.eat('*')) {
          state.tokenize = tokenNestedComment(depth + 1);
          return state.tokenize(stream, state);
        }
      }
      return 'comment';
    };
  }"] 
  "30064787332" -> "124554052584"  [ label = "DDG: tokenLongString"] 
  "30064787332" -> "124554052584"  [ label = "DDG: function tokenLongString = function tokenLongString(stream, state) {
    let prev, next;
    while (state.longString &amp;&amp; (next = stream.next()) != null) {
      if (prev === '|' &amp;&amp; next === '}') state.longString = false;
      prev = next;
    }
    if (!state.longString) {
      state.tokenize = false;
    }
    return 'string';
  }"] 
