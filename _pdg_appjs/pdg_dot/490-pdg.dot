  "30064778643" -> "124554052078"  [ label = "DDG: new Set()"] 
  "30064778640" -> "124554052078"  [ label = "DDG: const fixed = new Set()"] 
  "30064778644" -> "124554052078"  [ label = "DDG: KEEP_VISIT"] 
  "30064778644" -> "124554052078"  [ label = "DDG: const KEEP_VISIT = 1"] 
  "30064778645" -> "124554052078"  [ label = "DDG: this"] 
  "30064778645" -> "124554052078"  [ label = "DDG: ast"] 
  "30064778645" -> "124554052078"  [ label = "DDG: visitTarget(
    ast,
    value =&gt; getNodeCtor(value) === 'ASTWithSource',
    (node, parent) =&gt; {
      const baseStart = getBaseStart(parent);
      visitTarget(
        node,
        value =&gt; value.span,
        node =&gt; {
          if (!fixed.has(node)) {
            node.span.start += baseStart;
            node.span.end += baseStart;
            fixed.add(node);
          }

          return KEEP_VISIT;
        },
      );
    },
  )"] 
