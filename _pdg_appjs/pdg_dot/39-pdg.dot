  "30064771988" -> "124554051630"  [ label = "DDG: exports.fork"] 
  "30064771988" -> "124554051630"  [ label = "DDG: exports.fork = (req, res, next) =&gt; {
  // We cannot really &quot;fork&quot; an &quot;anonymous&quot; snippet because a user (astexplorer)
  // cannot fork it's own gist.
  const data = getDataFromBody(req.body);

  gh.getGist()
    .create(data)
    .then(response =&gt; res.json(response.data))
    .catch(next);
}"] 
