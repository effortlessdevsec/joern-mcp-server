  "30064790106" -> "124554052795"  [ label = "DDG: function create = function create(data) {
  return api(
    '/gist',
    {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify(data),
    },
  )
  .then(response =&gt; {
    if (response.ok) {
      return response.json();
    }
    throw new Error('Unable to create snippet.');
  })
  .then(data =&gt; new Revision(data));
}"] 
