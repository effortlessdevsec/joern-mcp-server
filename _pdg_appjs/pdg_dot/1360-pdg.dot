  "30064791973" -> "124554052944"  [ label = "DDG: function debounce = function debounce(f, timeout=100) {
  let timer;
  let lastArgs;
  let lastThis;

  return function(...args) {
    lastThis = this;
    lastArgs = args;
    if (timer) {
      return;
    }
    timer = setTimeout(() =&gt; {
      timer = null;
      f.apply(lastThis, lastArgs);
    }, timeout);
  };
}"] 
