  "30064771496" -> "124554051606"  [ label = "DDG: function linkStmt = function linkStmt(stmt, nextId) {
    if (!stmt) return nextId;
    const id = addNode(stmtLabel(stmt), stmt.type, stmt.loc);

    switch (stmt.type) {
      case &quot;IfStatement&quot;: {
        const thenFirst = getFirstStmt(stmt.consequent);
        const elseFirst = stmt.alternate ? getFirstStmt(stmt.alternate) : null;
        addEdge(id, linkStmt(thenFirst, nextId));
        if (elseFirst) addEdge(id, linkStmt(elseFirst, nextId));
        else addEdge(id, nextId);
        return id;
      }
      case &quot;WhileStatement&quot;: {
        const bodyFirst = getFirstStmt(stmt.body);
        const bodyId = bodyFirst ? linkStmt(bodyFirst, id) : id; // body flows back to condition
        addEdge(id, bodyId);
        addEdge(id, nextId);
        return id;
      }
      case &quot;DoWhileStatement&quot;: {
        const bodyFirst = getFirstStmt(stmt.body);
        const bodyId = bodyFirst ? linkStmt(bodyFirst, id) : id;
        addEdge(id, bodyId);
        addEdge(id, nextId);
        return id;
      }
      ..."] 
