        }
        onClick={canForkAndNotSave ? props.onFork : props.onSave}&gt;
        &lt;i
          className={cx({
            fa: true,
            'fa-spinner': savingOrForking,
            'fa-pulse': savingOrForking,
            'fa-floppy-o': !savingOrForking &amp;&amp; !canForkAndNotSave,
            'fa-code-fork': !savingOrForking &amp;&amp; canForkAndNotSave,
            'fa-fw': true,
          })}
        /&gt;
      &lt;/button&gt;
    &lt;/div&gt;"] 
