          hasOwnProperty(name) {
            // compare only against current-session &amp; very original methods
            if (!origMethods) {
              origMethods = new Set(Object.getOwnPropertyNames(this));
            }
            return origMethods.has(name) || sessionMethods.has(name);
          },
        })"] 
  "30064784414" -> "124554052391"  [ label = "DDG: jscodeshift.registerMethods = function (methods) {
          registerMethods.apply(this, arguments);
          for (let name in methods) {
            sessionMethods.add(name);
          }
        }"] 
