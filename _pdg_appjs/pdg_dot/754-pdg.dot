  "30064783319" -> "124554052338"  [ label = "DDG: errorReporter.reportMessageInternal = (sourceRange, message) =&gt; {
      if (options.TolerateErrors) {
        return;
      }
      let { start, end } = sourceRange;
      if (start.offset &lt; end.offset) {
        message += `: ${sourceRange}`;
      }
      let err = new SyntaxError(message);
      err.lineNumber = start.line + 1;
      err.columnNumber = start.column;
      throw err;
    }"] 
