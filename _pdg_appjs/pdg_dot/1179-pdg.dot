  "30064790094" -> "124554052795"  [ label = "DDG: function getIDAndRevisionFromHash = function getIDAndRevisionFromHash() {
  let match = global.location.hash.match(/^#\/gist\/([^/]+)(?:\/([^/]+))?/);
  if (match) {
    return {
      id: match[1],
      rev: match[2],
    };
  }
  return null;
}"] 
  "30064790095" -> "124554052795"  [ label = "DDG: fetchSnippet"] 
  "30064790095" -> "124554052795"  [ label = "DDG: function fetchSnippet = function fetchSnippet(snippetID, revisionID='latest') {
  return api(
    `/gist/${snippetID}` + (revisionID ? `/${revisionID}` : ''),
    {
      method: 'GET',
    },
  )
  .then(response =&gt; {
    if (response.ok) {
      return response.json();
    }
    switch (response.status) {
      case 404:
        throw new Error(`Snippet with ID ${snippetID}/${revisionID} doesn't exist.`);
      default:
        throw new Error('Unknown error.');
    }
  })
  .then(response =&gt; new Revision(response));
}"] 
  "30064790096" -> "124554052795"  [ label = "DDG: getSource"] 
  "30064790096" -> "124554052795"  [ label = "DDG: function getSource = function getSource(config, gist) {
  switch (config.v) {
    case 1:
      return gist.files['code.js'].content;
    case 2: {
      const ext = getParserByID(config.parserID).category.fileExtension;
      return gist.files[`source.${ext}`].content;
    }
  }
}"] 
