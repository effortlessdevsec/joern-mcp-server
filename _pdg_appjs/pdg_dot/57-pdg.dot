  "30064772269" -> "124554051647"  [ label = "DDG: function App = function App({showTransformer, hasError}) {
  return (
    &lt;&gt;
      &lt;ErrorMessageContainer /&gt;
      &lt;PasteDropTargetContainer id=&quot;main&quot; className={cx({hasError})}&gt;
        &lt;LoadingIndicatorContainer /&gt;
        &lt;SettingsDialogContainer /&gt;
        &lt;ShareDialogContainer /&gt;
        &lt;ToolbarContainer /&gt;
        &lt;GistBanner /&gt;
        &lt;SplitPane
          className=&quot;splitpane-content&quot;
          vertical={true}
          onResize={resize}&gt;
          &lt;SplitPane
            className=&quot;splitpane&quot;
            onResize={resize}&gt;
            &lt;CodeEditorContainer /&gt;
            &lt;ASTOutputContainer /&gt;
          &lt;/SplitPane&gt;
          {showTransformer ? &lt;TransformerContainer /&gt; : null}
        &lt;/SplitPane&gt;
      &lt;/PasteDropTargetContainer&gt;
    &lt;/&gt;
  );
}"] 
