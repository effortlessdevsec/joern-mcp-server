  "30064771648" -> "124554051615"  [ label = "DDG: sanitizeTypeName"] 
  "30064771648" -> "124554051615"  [ label = "DDG: function sanitizeTypeName = function sanitizeTypeName(typeName, fieldName, type) {
  if (type === 'boolean') {
    return 'bool';
  }

  switch(fieldName) {
    case 'operator':
    case 'kind':
      return 'string';
    case 'value':
      if (typeName === 'TemplateElement') {
        return 'TemplateElementValue';
      }
    default:
      if (/number [&gt;&lt;=]+ \d+/.test(type)) {
        return 'number';
      }
      return type;
  }
}"] 
